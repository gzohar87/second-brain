#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = ["click", "loguru", "pyyaml"]
# ///
"""sb — CLI for LLM Wiki vaults (second-brain framework)."""

import json
import re
import shutil
from datetime import date
from pathlib import Path

import click
import yaml
from loguru import logger

FRAMEWORK_DIR = Path(__file__).resolve().parent.parent
TEMPLATES_DIR = FRAMEWORK_DIR / "templates"
SKILLS_SRC = FRAMEWORK_DIR / ".claude" / "skills"
GLOBAL_SKILLS_DST = Path.home() / ".claude" / "skills"
GLOBAL_CLAUDE_MD = Path.home() / ".claude" / "CLAUDE.md"
VAULT_REGISTRY = Path.home() / ".claude" / "sb-vaults.json"
TODAY = date.today().isoformat()

OBSIDIAN_CONFIG = {
    "useMarkdownLinks": False,
    "newLinkFormat": "shortest",
    "showFrontmatter": True,
    "strictLineBreaks": True,
    "userIgnoreFilters": ["raw/"],
}

def load_registry() -> list[dict]:
    """Load the vault registry, returning an empty list if missing."""
    if VAULT_REGISTRY.exists():
        return json.loads(VAULT_REGISTRY.read_text()) or []
    return []


def save_registry(vaults: list[dict]):
    """Save the vault registry."""
    VAULT_REGISTRY.parent.mkdir(parents=True, exist_ok=True)
    VAULT_REGISTRY.write_text(json.dumps(vaults, indent=2) + "\n")


def render_global_claude_section() -> str:
    """Render the global CLAUDE.md section from its template, including registered vaults."""
    text = (TEMPLATES_DIR / "global-claude-md-snippet.md").read_text()
    text = text.replace("{{FRAMEWORK_DIR}}", str(FRAMEWORK_DIR))

    # Insert registered vaults before the closing marker
    vaults = load_registry()
    if vaults:
        lines = ["\n### Registered Vaults\n"]
        for v in vaults:
            lines.append(f"- **{v['name']}** — `{v['path']}`")
        vault_block = "\n".join(lines) + "\n"
        text = text.replace("<!-- END sb -->", vault_block + "<!-- END sb -->")

    return text.rstrip("\n")


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------


def strip_section(content: str, begin_marker: str, end_marker: str) -> str:
    """Remove everything between begin_marker and end_marker lines (inclusive)."""
    pattern = re.compile(
        rf"^[ \t]*{re.escape(begin_marker)}.*?{re.escape(end_marker)}[ \t]*$",
        re.MULTILINE | re.DOTALL,
    )
    return pattern.sub("", content)


def upsert_section(filepath: Path, begin_marker: str, end_marker: str, new_content: str):
    """Strip old section if present, append new section."""
    if filepath.exists():
        content = filepath.read_text()
        content = strip_section(content, begin_marker, end_marker)
    else:
        filepath.parent.mkdir(parents=True, exist_ok=True)
        content = ""
    content = content.rstrip("\n")
    if content:
        content += "\n\n"
    content += new_content + "\n"
    filepath.write_text(content)


def render_template(template_name: str, title: str, wiki_path: str) -> str:
    """Read a template and substitute placeholders."""
    text = (TEMPLATES_DIR / template_name).read_text()
    return (
        text.replace("{{DATE}}", TODAY)
        .replace("{{TITLE}}", title)
        .replace("{{WIKI_PATH}}", wiki_path)
    )


def install_skills():
    """Copy wiki skills to the global skills directory."""
    GLOBAL_SKILLS_DST.mkdir(parents=True, exist_ok=True)
    installed = []
    for skill_dir in sorted(SKILLS_SRC.glob("wiki-*")):
        if skill_dir.is_dir():
            dst = GLOBAL_SKILLS_DST / skill_dir.name
            if dst.exists():
                shutil.rmtree(dst)
            shutil.copytree(skill_dir, dst)
            installed.append(skill_dir.name)
            logger.info(f"Installed skill: {skill_dir.name}")
    return installed


def install_global_claude_md():
    """Manage the sb section in ~/.claude/CLAUDE.md."""
    upsert_section(GLOBAL_CLAUDE_MD, "<!-- BEGIN sb -->", "<!-- END sb -->", render_global_claude_section())
    logger.info(f"Updated {GLOBAL_CLAUDE_MD}")


def resolve_vault(path_str: str = ".") -> Path:
    """Resolve a path to a vault root (direct detection only)."""
    p = Path(path_str).resolve()
    if (p / "index.md").exists() and ((p / "wiki").is_dir() or (p / "meta").is_dir()):
        return p
    raise click.ClickException(f"No vault found at '{p}'")


def load_config(vault: Path) -> dict:
    """Load config.yml from vault, returning empty dict if missing."""
    config_file = vault / "config.yml"
    if config_file.exists():
        return yaml.safe_load(config_file.read_text()) or {}
    return {}


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------


@click.group()
def cli():
    """sb — CLI for LLM Wiki vaults."""
    pass


@cli.command()
def install():
    """Install skills globally and update ~/.claude/CLAUDE.md."""
    installed = install_skills()
    install_global_claude_md()
    click.echo()
    click.echo("=== Installed ===")
    click.echo(f"  Skills: {', '.join(installed)}")
    click.echo(f"  CLAUDE.md: {GLOBAL_CLAUDE_MD}")
    click.echo("  Restart Claude Code to detect changes.")


@cli.command()
@click.argument("path", type=click.Path())
def init(path: str):
    """Create a new wiki vault at PATH."""
    vault = Path(path).resolve()
    vault_name = vault.name

    if (vault / "wiki").exists():
        raise click.ClickException(f"Vault already exists at '{vault}'")

    # Create directories
    (vault / "raw" / "assets").mkdir(parents=True, exist_ok=True)
    (vault / "wiki").mkdir(parents=True, exist_ok=True)

    # Template files
    for tmpl in ("index.md", "log.md", "tracker.md"):
        content = render_template(tmpl, title=vault_name, wiki_path="wiki/")
        (vault / tmpl).write_text(content)
        logger.info(f"Created {tmpl}")

    # Automation config
    shutil.copy2(TEMPLATES_DIR / "config.yml", vault / "config.yml")
    logger.info("Created config.yml")

    # Obsidian config
    obsidian_dir = vault / ".obsidian"
    obsidian_dir.mkdir(exist_ok=True)
    (obsidian_dir / "app.json").write_text(json.dumps(OBSIDIAN_CONFIG, indent=2) + "\n")

    click.echo()
    click.echo("=== Vault created ===")
    click.echo(f"  Path       : {vault}")
    click.echo(f"  Directories: raw/  raw/assets/  wiki/")
    click.echo(f"  Files      : index.md  log.md  tracker.md  config.yml")
    click.echo()
    click.echo("Next steps:")
    click.echo(f"  sb register {vault}")


def update_vault(vault: Path):
    """Apply vault-level updates: add missing scaffold files, refresh config."""
    if not (vault / "index.md").exists() or not (vault / "wiki").is_dir():
        return
    vault_name = vault.name
    logger.info(f"Updating vault: {vault}")

    # Add tracker.md if missing
    if not (vault / "tracker.md").exists():
        content = render_template("tracker.md", title=vault_name, wiki_path="wiki/")
        (vault / "tracker.md").write_text(content)
        logger.info("  Added tracker.md")

    # Add config.yml if missing
    if not (vault / "config.yml").exists():
        shutil.copy2(TEMPLATES_DIR / "config.yml", vault / "config.yml")
        logger.info("  Added config.yml")

    # Refresh .obsidian/app.json
    obsidian_dir = vault / ".obsidian"
    obsidian_dir.mkdir(exist_ok=True)
    (obsidian_dir / "app.json").write_text(json.dumps(OBSIDIAN_CONFIG, indent=2) + "\n")


@cli.command()
def update():
    """Refresh global install and update all registered vaults."""
    # 1. Global refresh
    installed = install_skills()
    install_global_claude_md()
    click.echo(f"  Skills refreshed: {', '.join(installed)}")

    # 2. Update all registered vaults
    for entry in load_registry():
        vault = Path(entry["path"])
        if vault.is_dir():
            update_vault(vault)

    # 3. If cwd is itself a vault (even if not registered), update it
    cwd = Path.cwd()
    if (cwd / "index.md").exists() and (cwd / "wiki").is_dir():
        update_vault(cwd)

    click.echo()
    click.echo("=== Updated ===")
    click.echo("  Restart Claude Code to pick up changes.")


@cli.command()
@click.argument("vault_path", type=click.Path(exists=True))
def register(vault_path: str):
    """Register a vault so Claude sees it in every session."""
    vault = Path(vault_path).resolve()
    if not (vault / "index.md").exists():
        raise click.ClickException(f"'{vault}' doesn't look like a wiki (no index.md)")

    vaults = load_registry()
    if any(v["path"] == str(vault) for v in vaults):
        raise click.ClickException(f"Already registered: {vault.name}")

    vaults.append({"name": vault.name, "path": str(vault)})
    save_registry(vaults)
    install_global_claude_md()  # re-render with new vault list

    click.echo(f"Registered: {vault.name} ({vault})")
    click.echo("  Restart Claude Code to pick up changes.")


@cli.command()
@click.argument("name")
def unregister(name: str):
    """Remove a vault from the global registry."""
    vaults = load_registry()
    before = len(vaults)
    vaults = [v for v in vaults if v["name"] != name]
    if len(vaults) == before:
        raise click.ClickException(f"No vault registered with name '{name}'")

    save_registry(vaults)
    install_global_claude_md()  # re-render without removed vault

    click.echo(f"Unregistered: {name}")
    click.echo("  Restart Claude Code to pick up changes.")


def show_vault_health(vault: Path):
    """Print health and automation info for a single vault."""
    scaffold = {"index", "log", "tracker"}
    all_md = [
        p for p in vault.rglob("*.md")
        if "raw" not in p.relative_to(vault).parts
        and ".obsidian" not in p.relative_to(vault).parts
    ]
    all_pages = {p.stem for p in all_md}
    content_pages = all_pages - scaffold

    def extract_link_targets(text: str) -> set[str]:
        targets = set()
        for m in re.finditer(r"\[\[([^\]|]+)(?:\|[^\]]*)?\]\]", text):
            page = m.group(1).split("#")[0]
            if page:
                targets.add(page)
        return targets

    index_file = vault / "index.md"
    indexed = set()
    if index_file.exists():
        indexed = extract_link_targets(index_file.read_text())

    all_links = set()
    for md in all_md:
        all_links |= extract_link_targets(md.read_text())

    orphans = content_pages - indexed
    broken = all_links - all_pages

    click.echo(f"  Pages: {len(all_pages)} total ({len(content_pages)} content + {len(all_pages & scaffold)} scaffold)")
    if orphans:
        click.echo(f"  Orphans (not in index): {', '.join(sorted(orphans))}")
    if broken:
        click.echo(f"  Broken links: {', '.join(sorted(broken))}")
    if not orphans and not broken:
        click.echo("  No issues")

    config = load_config(vault)
    auto = config.get("automation", {})
    for name in ("distill", "lint"):
        section = auto.get(name, {})
        enabled = section.get("enabled", False)
        schedule = section.get("schedule", "—")
        status_str = f"enabled ({schedule})" if enabled else "disabled"
        click.echo(f"  {name}: {status_str}")


@cli.command()
def status():
    """Show installed skills and registered vault health."""
    # 1. Installed skills
    installed = sorted(
        d.name for d in GLOBAL_SKILLS_DST.glob("wiki-*") if d.is_dir()
    ) if GLOBAL_SKILLS_DST.exists() else []

    click.echo("=== Skills ===")
    if installed:
        for s in installed:
            click.echo(f"  {s}")
    else:
        click.echo("  (none installed)")

    # 2. Registered vaults
    vaults = load_registry()
    click.echo()
    click.echo("=== Vaults ===")
    if not vaults:
        click.echo("  (none registered)")
        return

    for entry in vaults:
        vault = Path(entry["path"])
        click.echo(f"\n  {entry['name']} — {vault}")
        if vault.is_dir() and (vault / "index.md").exists():
            show_vault_health(vault)
        else:
            click.echo("  ⚠ path not found")


@cli.command()
@click.argument("vault_path", default=".", type=click.Path(exists=True))
def config(vault_path: str):
    """Show vault automation config."""
    vault = resolve_vault(vault_path)
    config_file = vault / "config.yml"
    if config_file.exists():
        click.echo(config_file.read_text())
    else:
        click.echo("No config.yml found. Run 'sb update' to create one with defaults.")


if __name__ == "__main__":
    cli()
