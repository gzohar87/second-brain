#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = ["click", "loguru"]
# ///
"""sb — CLI for LLM Wiki vaults (second-brain framework)."""

import json
import re
import shutil
from datetime import date
from pathlib import Path

import click
from loguru import logger

FRAMEWORK_DIR = Path(__file__).resolve().parent.parent
TEMPLATES_DIR = FRAMEWORK_DIR / "templates"
SKILLS_SRC = FRAMEWORK_DIR / ".claude" / "skills"
GLOBAL_SKILLS_DST = Path.home() / ".claude" / "skills"
GLOBAL_CLAUDE_MD = Path.home() / ".claude" / "CLAUDE.md"
TODAY = date.today().isoformat()

OBSIDIAN_CONFIG = {
    "useMarkdownLinks": False,
    "newLinkFormat": "shortest",
    "showFrontmatter": True,
    "strictLineBreaks": True,
    "userIgnoreFilters": ["raw/"],
}

def render_global_claude_section() -> str:
    """Render the global CLAUDE.md section from its template."""
    text = (TEMPLATES_DIR / "global-claude-md-snippet.md").read_text()
    return text.replace("{{FRAMEWORK_DIR}}", str(FRAMEWORK_DIR)).rstrip("\n")


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------


def strip_section(content: str, begin_marker: str, end_marker: str) -> str:
    """Remove everything between begin_marker and end_marker lines (inclusive)."""
    pattern = re.compile(
        rf"^[ \t]*{re.escape(begin_marker)}.*?{re.escape(end_marker)}[ \t]*$",
        re.MULTILINE | re.DOTALL,
    )
    return pattern.sub("", content)


def upsert_section(filepath: Path, begin_marker: str, end_marker: str, new_content: str):
    """Strip old section if present, append new section."""
    if filepath.exists():
        content = filepath.read_text()
        content = strip_section(content, begin_marker, end_marker)
    else:
        filepath.parent.mkdir(parents=True, exist_ok=True)
        content = ""
    content = content.rstrip("\n")
    if content:
        content += "\n\n"
    content += new_content + "\n"
    filepath.write_text(content)


def render_template(template_name: str, title: str, wiki_path: str) -> str:
    """Read a template and substitute placeholders."""
    text = (TEMPLATES_DIR / template_name).read_text()
    return (
        text.replace("{{DATE}}", TODAY)
        .replace("{{TITLE}}", title)
        .replace("{{WIKI_PATH}}", wiki_path)
    )


def install_skills():
    """Copy wiki skills to the global skills directory."""
    GLOBAL_SKILLS_DST.mkdir(parents=True, exist_ok=True)
    installed = []
    for skill_dir in sorted(SKILLS_SRC.glob("wiki-*")):
        if skill_dir.is_dir():
            dst = GLOBAL_SKILLS_DST / skill_dir.name
            if dst.exists():
                shutil.rmtree(dst)
            shutil.copytree(skill_dir, dst)
            installed.append(skill_dir.name)
            logger.info(f"Installed skill: {skill_dir.name}")
    return installed


def install_global_claude_md():
    """Manage the sb section in ~/.claude/CLAUDE.md."""
    upsert_section(GLOBAL_CLAUDE_MD, "<!-- BEGIN sb -->", "<!-- END sb -->", render_global_claude_section())
    logger.info(f"Updated {GLOBAL_CLAUDE_MD}")


WIKI_BEGIN = "<!-- BEGIN second-brain wiki conventions -->"
WIKI_END = "<!-- END second-brain wiki conventions -->"


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------


@click.group()
def cli():
    """sb — CLI for LLM Wiki vaults."""
    pass


@cli.command()
def install():
    """Install skills globally and update ~/.claude/CLAUDE.md."""
    installed = install_skills()
    install_global_claude_md()
    click.echo()
    click.echo("=== Installed ===")
    click.echo(f"  Skills: {', '.join(installed)}")
    click.echo(f"  CLAUDE.md: {GLOBAL_CLAUDE_MD}")
    click.echo("  Restart Claude Code to detect changes.")


@cli.command()
@click.argument("path", type=click.Path())
def init(path: str):
    """Create a new wiki vault at PATH."""
    vault = Path(path).resolve()
    vault_name = vault.name

    if (vault / "wiki").exists():
        raise click.ClickException(f"Vault already exists at '{vault}'")

    # Create directories
    (vault / "raw" / "assets").mkdir(parents=True, exist_ok=True)
    (vault / "wiki").mkdir(parents=True, exist_ok=True)

    # Template files
    for tmpl in ("index.md", "log.md", "tracker.md"):
        content = render_template(tmpl, title=vault_name, wiki_path="wiki/")
        (vault / tmpl).write_text(content)
        logger.info(f"Created {tmpl}")

    # Obsidian config
    obsidian_dir = vault / ".obsidian"
    obsidian_dir.mkdir(exist_ok=True)
    (obsidian_dir / "app.json").write_text(json.dumps(OBSIDIAN_CONFIG, indent=2) + "\n")

    click.echo()
    click.echo("=== Vault created ===")
    click.echo(f"  Path       : {vault}")
    click.echo(f"  Directories: raw/  raw/assets/  wiki/")
    click.echo(f"  Files      : index.md  log.md  tracker.md")
    click.echo()
    click.echo("Next steps:")
    click.echo(f"  sb link {vault} --repo <your-repo>")


def update_vault(vault: Path):
    """Apply vault-level updates: add missing scaffold files, refresh config."""
    if not (vault / "index.md").exists() or not (vault / "wiki").is_dir():
        return
    vault_name = vault.name
    logger.info(f"Updating vault: {vault}")

    # Add tracker.md if missing
    if not (vault / "tracker.md").exists():
        content = render_template("tracker.md", title=vault_name, wiki_path="wiki/")
        (vault / "tracker.md").write_text(content)
        logger.info("  Added tracker.md")

    # Refresh .obsidian/app.json
    obsidian_dir = vault / ".obsidian"
    obsidian_dir.mkdir(exist_ok=True)
    (obsidian_dir / "app.json").write_text(json.dumps(OBSIDIAN_CONFIG, indent=2) + "\n")


@cli.command()
def update():
    """Refresh global install and update linked repo if applicable."""
    # 1. Global refresh
    installed = install_skills()
    install_global_claude_md()
    click.echo(f"  Skills refreshed: {', '.join(installed)}")

    # 2. If cwd has a wiki link, refresh the snippet and update the linked vault
    cwd = Path.cwd()
    claude_md = cwd / "CLAUDE.md"
    if claude_md.exists():
        content = claude_md.read_text()
        if WIKI_BEGIN in content:
            match = re.search(r"Wiki location: `([^`]+)`", content)
            if match:
                wiki_path = match.group(1)
                vault_name = Path(wiki_path.rstrip("/")).name
                snippet = render_template("claude-md-snippet.md", title=vault_name, wiki_path=wiki_path)
                upsert_section(claude_md, WIKI_BEGIN, WIKI_END, snippet)
                logger.info(f"Refreshed wiki snippet in {claude_md}")
                # Update the linked vault itself
                vault = Path(wiki_path.rstrip("/"))
                if vault.is_dir():
                    update_vault(vault)

    # 3. If cwd is itself a vault, update it directly
    if (cwd / "index.md").exists() and (cwd / "wiki").is_dir():
        update_vault(cwd)

    click.echo()
    click.echo("=== Updated ===")
    click.echo("  Restart Claude Code to pick up changes.")


@cli.command()
@click.argument("wiki_path", type=click.Path(exists=True))
@click.option("--repo", default=".", type=click.Path(exists=True), help="Target repo (default: cwd)")
def link(wiki_path: str, repo: str):
    """Point a repo at an external wiki vault."""
    wiki = Path(wiki_path).resolve()
    repo_root = Path(repo).resolve()

    if not (wiki / "index.md").exists():
        raise click.ClickException(f"'{wiki}' doesn't look like a wiki (no index.md)")

    claude_md = repo_root / "CLAUDE.md"
    if claude_md.exists() and WIKI_BEGIN in claude_md.read_text():
        raise click.ClickException("Repo already linked to a wiki. Run 'sb unlink' first.")

    vault_name = wiki.name
    snippet = render_template("claude-md-snippet.md", title=vault_name, wiki_path=f"{wiki}/")
    upsert_section(claude_md, WIKI_BEGIN, WIKI_END, snippet)

    click.echo(f"Linked: {repo_root} → {wiki}")


@cli.command()
@click.option("--repo", default=".", type=click.Path(exists=True), help="Target repo (default: cwd)")
def unlink(repo: str):
    """Remove wiki link from a repo's CLAUDE.md."""
    repo_root = Path(repo).resolve()
    claude_md = repo_root / "CLAUDE.md"

    if not claude_md.exists():
        raise click.ClickException("No CLAUDE.md found")

    content = claude_md.read_text()
    if WIKI_BEGIN not in content:
        raise click.ClickException("No wiki link found in CLAUDE.md")

    content = strip_section(content, WIKI_BEGIN, WIKI_END).strip() + "\n"
    claude_md.write_text(content)

    click.echo(f"Unlinked wiki from {repo_root}")


@cli.command()
def status():
    """Show installed skills, linked wiki, and vault health."""
    # 1. Installed skills
    installed = sorted(
        d.name for d in GLOBAL_SKILLS_DST.glob("wiki-*") if d.is_dir()
    ) if GLOBAL_SKILLS_DST.exists() else []

    click.echo("=== Skills ===")
    if installed:
        for s in installed:
            click.echo(f"  {s}")
    else:
        click.echo("  (none installed)")

    # 2. Detect vault — either cwd is a vault, or cwd has a linked wiki
    cwd = Path.cwd()
    vault = None
    vault_source = None

    if (cwd / "index.md").exists() and (cwd / "wiki").is_dir():
        vault = cwd
        vault_source = "vault (cwd)"
    else:
        claude_md = cwd / "CLAUDE.md"
        if claude_md.exists():
            content = claude_md.read_text()
            match = re.search(r"Wiki location: `([^`]+)`", content)
            if match:
                linked = Path(match.group(1).rstrip("/"))
                if linked.is_dir():
                    vault = linked
                    vault_source = f"linked → {vault}"

    click.echo()
    click.echo("=== Wiki ===")
    if vault:
        click.echo(f"  Source: {vault_source}")
    else:
        click.echo("  (no vault detected)")
        return

    # 3. Vault health — scan all .md files recursively, skip raw/
    scaffold = {"index", "log", "tracker"}
    all_md = [
        p for p in vault.rglob("*.md")
        if "raw" not in p.relative_to(vault).parts
        and ".obsidian" not in p.relative_to(vault).parts
    ]
    all_pages = {p.stem for p in all_md}
    content_pages = all_pages - scaffold

    def extract_link_targets(text: str) -> set[str]:
        """Extract page names from [[wikilinks]], stripping anchors and aliases."""
        targets = set()
        for m in re.finditer(r"\[\[([^\]|]+)(?:\|[^\]]*)?\]\]", text):
            page = m.group(1).split("#")[0]  # strip anchor
            if page:
                targets.add(page)
        return targets

    # Pages listed in index.md
    index_file = vault / "index.md"
    indexed = set()
    if index_file.exists():
        indexed = extract_link_targets(index_file.read_text())

    # Scan all md files for [[wikilinks]]
    all_links = set()
    for md in all_md:
        all_links |= extract_link_targets(md.read_text())

    orphans = content_pages - indexed
    broken = all_links - all_pages

    click.echo()
    click.echo("=== Health ===")
    click.echo(f"  Pages: {len(all_pages)} total ({len(content_pages)} content + {len(all_pages & scaffold)} scaffold)")
    if orphans:
        click.echo(f"  Orphans (not in index): {', '.join(sorted(orphans))}")
    else:
        click.echo("  Orphans: none")
    if broken:
        click.echo(f"  Broken links: {', '.join(sorted(broken))}")
    else:
        click.echo("  Broken links: none")


if __name__ == "__main__":
    cli()
